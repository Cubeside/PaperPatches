From 4409efaf65e96ab66e29898f54e280ce7728275c Mon Sep 17 00:00:00 2001
From: Brokkonaut <hannos17@gmx.de>
Date: Thu, 9 Jan 2025 09:01:31 +0100
Subject: [PATCH] NoAI Mobs are not pushable

---
 net/minecraft/world/entity/Entity.java | 22 ++++++++++++++++++++--
 1 file changed, 20 insertions(+), 2 deletions(-)

diff --git a/net/minecraft/world/entity/Entity.java b/net/minecraft/world/entity/Entity.java
index 9cd46a86..2bcbd1d3 100644
--- a/net/minecraft/world/entity/Entity.java
+++ b/net/minecraft/world/entity/Entity.java
@@ -2308,6 +2308,12 @@ public abstract class Entity
     public void playerTouch(final Player player) {
     }
 
+    // Brokko start - pushable
+    private boolean isRealPushable() {
+        return !(this instanceof Mob) || !((Mob) this).isNoAi();
+    }
+    // Brokko end
+
     public void push(final Entity entity) {
         if (!this.isPassengerOfSameVehicle(entity)) {
             if (!entity.noPhysics && !this.noPhysics) {
@@ -2329,11 +2335,23 @@ public abstract class Entity
                     xa *= 0.05F;
                     za *= 0.05F;
                     if (!this.isVehicle() && this.isPushable()) {
-                        this.push(-xa, 0.0, -za);
+                        // Brokko start - isRealPushable
+                        if (this.isRealPushable()) {
+                            this.push(-xa, 0.0, -za);
+                        } else {
+                            this.needsSync = true;
+                        }
+                        // Brokko end
                     }
 
                     if (!entity.isVehicle() && entity.isPushable()) {
-                        entity.push(xa, 0.0, za);
+                        // Brokko start - isRealPushable
+                        if (entity.isRealPushable()) {
+                            entity.push(xa, 0.0D, za);
+                        } else {
+                            entity.needsSync = true;
+                        }
+                        // Brokko end
                     }
                 }
             }
-- 
