From 4cc2e50c1aa96b5b73d1d08e4fe441648ee97dfb Mon Sep 17 00:00:00 2001
From: Brokkonaut <hannos17@gmx.de>
Date: Sat, 4 Apr 2026 01:04:50 +0200
Subject: [PATCH 1/2] only log game protocol when debug is active

---
 .../net/md_5/bungee/protocol/MinecraftDecoder.java     | 10 +++++-----
 .../main/java/net/md_5/bungee/netty/HandlerBoss.java   |  2 +-
 2 files changed, 6 insertions(+), 6 deletions(-)

diff --git a/protocol/src/main/java/net/md_5/bungee/protocol/MinecraftDecoder.java b/protocol/src/main/java/net/md_5/bungee/protocol/MinecraftDecoder.java
index 15832a8c..5d2d1181 100644
--- a/protocol/src/main/java/net/md_5/bungee/protocol/MinecraftDecoder.java
+++ b/protocol/src/main/java/net/md_5/bungee/protocol/MinecraftDecoder.java
@@ -65,7 +65,7 @@ public class MinecraftDecoder extends MessageToMessageDecoder<ByteBuf>
                 if ( in.isReadable() )
                 {
                     // Waterfall start: Additional DoS mitigations
-                    if(!DEBUG) {
+                    if(!DEBUG || protocol != Protocol.GAME ) { // Brokko - Always log exceptions from game protocol
                         throw PACKET_NOT_READ_TO_END;
                     }
                     // Waterfall end
@@ -80,7 +80,7 @@ public class MinecraftDecoder extends MessageToMessageDecoder<ByteBuf>
             slice = null;
         } catch (BadPacketException | IndexOutOfBoundsException e) {
             // Waterfall start: Additional DoS mitigations
-            if(!DEBUG) {
+            if(!DEBUG || protocol != Protocol.GAME ) { // Brokko - Always log exceptions from game protocol
                 throw e;
             }
             // Waterfall end
@@ -95,7 +95,7 @@ public class MinecraftDecoder extends MessageToMessageDecoder<ByteBuf>
             throw new FastDecoderException("Error decoding packet " + packetTypeStr + " with contents:\n" + ByteBufUtil.prettyHexDump(slice), e); // Waterfall
             // Waterfall start
         } catch (Exception e) {
-            if (!DEBUG) {
+            if (!DEBUG || protocol != Protocol.GAME ) { // Brokko - Always log exceptions from game protocol
                 throw e;
             }
             final String packetTypeStr;
@@ -158,7 +158,7 @@ public class MinecraftDecoder extends MessageToMessageDecoder<ByteBuf>
     }
 
     private Exception handleOverflow(DefinedPacket packet, int expected, int actual, int packetId) {
-        if (DEBUG) {
+        if (DEBUG && protocol == Protocol.GAME ) { // Brokko - Always log exceptions from game protocol
             throw new CorruptedFrameException( "Packet " + packet.getClass() + " " + packetId
                     + " Protocol " + protocolVersion + " was too big (expected "
                     + expected + " bytes, got " + actual + " bytes)");
@@ -168,7 +168,7 @@ public class MinecraftDecoder extends MessageToMessageDecoder<ByteBuf>
     }
 
     private Exception handleUnderflow(DefinedPacket packet, int expected, int actual, int packetId) {
-        if (DEBUG) {
+        if (DEBUG && protocol == Protocol.GAME ) { // Brokko - Always log exceptions from game protocol
             throw new CorruptedFrameException( "Packet " + packet.getClass() + " " + packetId
                     + " Protocol " + protocolVersion + " was too small (expected "
                     + expected + " bytes, got " + actual + " bytes)");
diff --git a/proxy/src/main/java/net/md_5/bungee/netty/HandlerBoss.java b/proxy/src/main/java/net/md_5/bungee/netty/HandlerBoss.java
index 925cc346..0df3e86f 100644
--- a/proxy/src/main/java/net/md_5/bungee/netty/HandlerBoss.java
+++ b/proxy/src/main/java/net/md_5/bungee/netty/HandlerBoss.java
@@ -183,7 +183,7 @@ public class HandlerBoss extends ChannelInboundHandlerAdapter
                 } else if ( cause instanceof DecoderException )
                 {
                     // Waterfall start
-                    if (net.md_5.bungee.protocol.MinecraftDecoder.DEBUG) {
+                    if (net.md_5.bungee.protocol.MinecraftDecoder.DEBUG && !( handler instanceof InitialHandler )) {
                         java.util.logging.LogRecord logRecord = new java.util.logging.LogRecord(Level.WARNING, "{0} - A decoder exception has been thrown:");
                         logRecord.setParameters(new Object[]{handler});
                         logRecord.setThrown(cause);
-- 
